{
  "name": "claimflow-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:backend": "python -m uvicorn main:app --reload --app-dir claims-management/backend",
    "dev:frontend": "npm --prefix claims-management/frontend run dev",
    "dev:full": "concurrently -k -n BACKEND,FRONTEND -c green,blue \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
